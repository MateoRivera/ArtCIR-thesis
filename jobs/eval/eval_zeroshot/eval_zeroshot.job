#!/bin/bash
#SBATCH --time=23:30:00
#SBATCH --mail-type=ALL
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --partition=RTX
#SBATCH --gpus=1
#SBATCH --job-name=Qwen3VLEmbedder/embedding
#SBATCH --mem=32GB
#SBATCH --output=outputs/logs/eval/eval_zeroshot/eval_artcir_test.log
#SBATCH --error=outputs/logs/eval/eval_zeroshot/eval_artcir_test.err

# execute script
echo "Starting job at $(date) - Embedding task"
cd /nfs/home/rivera/artkb-dataset/ArtCIR-thesis || exit 1

if ! command -v uv >/dev/null 2>&1; then
    echo "Error: uv is not available in PATH"
    exit 1
fi

SPLIT="test"
BATCH_SIZE=16

unset VIRTUAL_ENV
uv run scripts/eval/eval_zeroshot/eval_artcir.py \
    --annotation_path_prefix ./data/artcir/annotations \
    --image_path_prefix ./data/artcir/images \
    --split $SPLIT \
    --db_path ./data/artcir/database/embeddings_zeroshot.db \
    --retrieval_results_path_prefix ./outputs/eval

echo "Job finished at $(date)"