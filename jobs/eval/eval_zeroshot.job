#!/bin/bash
#SBATCH --time=6-00:00:00
#SBATCH --mail-type=ALL
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --partition=RTX
#SBATCH --gpus=0
#SBATCH --job-name=artcir_thesis/eval_zeroshot
#SBATCH --mem=64GB
#SBATCH --output=outputs/eval/eval_zeroshot2.log
#SBATCH --error=outputs/eval/eval_zeroshot2.err

# execute script
echo "Starting job at $(date) - Zero-shot evaluation task"
cd /nfs/home/rivera/artkb-dataset/ArtCIR-thesis || exit 1

if ! command -v uv >/dev/null 2>&1; then
    echo "Error: uv is not available in PATH"
    exit 1
fi

ORIGINAL_MODEL_ID="Qwen/Qwen2-VL-7B-Instruct"
MODEL_ID="code-kunkun/LamRA-Ret"

uv run accelerate launch --main_process_port 29508 scripts/eval/eval_zeroshot/eval_artcir.py \
    --annotation_path_prefix ./data/artcir/annotations \
    --image_path_prefix ./data/artcir/images \
    --split test \
    --batch_size 16 \
    --original_model_id $ORIGINAL_MODEL_ID \
    --model_id $MODEL_ID \
    --save_for_rerank

echo "Job finished at $(date)"