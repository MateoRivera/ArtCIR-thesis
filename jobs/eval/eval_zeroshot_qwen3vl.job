#!/bin/bash
#SBATCH --time=4-00:00:00
#SBATCH --mail-type=ALL
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=8
#SBATCH --partition=RTX
#SBATCH --gpus=0
#SBATCH --job-name=artcir_thesis/eval_zeroshot_qwen3vl
#SBATCH --mem=32GB
#SBATCH --output=outputs/eval/eval_zeroshot_qwen3vl.log
#SBATCH --error=outputs/eval/eval_zeroshot_qwen3vl.err

# execute script
echo "Starting job at $(date) - Zero-shot evaluation task"
cd /nfs/home/rivera/artkb-dataset/ArtCIR-thesis || exit 1

if ! command -v uv >/dev/null 2>&1; then
    echo "Error: uv is not available in PATH"
    exit 1
fi

MODEL_ID="Qwen/Qwen3-VL-Embedding-2B"
TYPE="query"
SPLIT="test"
BATCH_SIZE=2

unset VIRTUAL_ENV
uv run scripts/eval/eval_zeroshot/eval_artcir_qwen3vl.py \
    --annotation_path_prefix ./data/artcir/annotations \
    --image_path_prefix ./data/artcir/images \
    --type $TYPE \
    --split $SPLIT \
    --batch_size $BATCH_SIZE \
    --model_id $MODEL_ID \
    --db_path ./data/artcir/database/embeddings.db

echo "Job finished at $(date)"